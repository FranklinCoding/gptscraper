# Polling interval in seconds for stock news sources
POLL_SECONDS=15

# Historical backfill window at startup (days)
BACKFILL_DAYS=60

# Minutes after an alert before its price move is evaluated
EVAL_WINDOW_MINUTES=60

# Minimum absolute move to count as directional instead of flat
EVAL_THRESHOLD_PCT=0.25
# Optional path to custom ticker symbol list (one symbol per line)
# TICKER_FILE=/app/data/tickers.txt
